# Copy this file to deploy.env and fill in your values
# deploy.env is gitignored and should NEVER be committed

# SSH connection
DEPLOY_HOST=your-vm-ip-or-hostname
DEPLOY_USER=your-username
DEPLOY_SSH_KEY=~/.ssh/your-key

# Remote paths
DEPLOY_HOME=/home/your-username
DEPLOY_WORKDIR=/home/your-username/blackcat
DEPLOY_CONFIG_PATH=/home/your-username/blackcat/blackcat.yaml
BLACKCAT_BINARY=/usr/local/bin/blackcat
OPENCODE_BINARY=/usr/local/bin/opencode
OPENCODE_PORT=4096

# Secrets (NEVER commit deploy.env)
VAULT_PASSPHRASE=your-vault-passphrase
