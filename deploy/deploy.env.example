# Copy this file to deploy.env and fill in your values
# deploy.env is gitignored and should NEVER be committed
#
# One-time prerequisite (requires sudo):
#   sudo loginctl enable-linger $USER
# This allows user-level systemd services to persist after logout.

# SSH connection
DEPLOY_HOST=your-vm-ip
DEPLOY_USER=your-username
DEPLOY_SSH_KEY=~/.ssh/your-key

# Remote paths (user-space — no root required)
DEPLOY_HOME=/home/your-username
DEPLOY_WORKDIR=/home/your-username/blackcat
DEPLOY_CONFIG_PATH=/home/your-username/.blackcat/config.yaml
BLACKCAT_BINARY=/home/your-username/.blackcat/bin/blackcat
OPENCODE_BINARY=/home/your-username/.blackcat/bin/opencode
OPENCODE_PORT=4096

# Secrets (NEVER commit deploy.env)
VAULT_PASSPHRASE=your-vault-passphrase
